{
  "name": "@narai/notion-agent-connector",
  "version": "3.1.0",
  "description": "Read-only Notion connector: search, pages, databases. Built on @narai/connector-toolkit with an approval gate and hardship logging. JSON-envelope CLI + library API.",
  "_devLinkNote": "The `@narai/connector-config: file:../connector-config` dep must be flipped to `^1.1.0` at publish time. It exists only to support dev linking against the unpublished local sibling repo. Publish ordering: connector-config@1.1.0 first, then this package.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./cli": "./dist/cli.js"
  },
  "bin": {
    "notion-agent-connector": "./dist/cli.js"
  },
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/narailabs/notion-agent-connector.git"
  },
  "bugs": {
    "url": "https://github.com/narailabs/notion-agent-connector/issues"
  },
  "homepage": "https://github.com/narailabs/notion-agent-connector#readme",
  "engines": {
    "node": ">=20.0.0"
  },
  "files": [
    "dist/",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@narai/connector-config": "file:../connector-config",
    "@narai/connector-toolkit": "^3.1.0",
    "@narai/credential-providers": "^0.2.1",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/node": "^20.19.39",
    "typescript": "^5.9.3",
    "vitest": "^3.0.0"
  },
  "license": "MIT",
  "keywords": [
    "notion",
    "connector",
    "claude",
    "agent"
  ]
}
